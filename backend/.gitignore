# 依赖
node_modules/

# 构建产物
dist/
dist-scripts/

# Prisma 生成的 client（由 prisma generate 重建）
src/generated/

# SQLite 数据库文件（本地数据，不入库）
data/*.db
data/*.db-journal
data/*.db-wal
data/*.db-shm

# 运行时数据（v7 起以 SQLite 为准；JSON 仅为迁移前的历史备份）
data/sessions/
data/reports/
data/monitor-config.json

# RAG 向量文件（运行时生成，体积大，不入库）
data/vectors/

# 环境变量
.env
.env.local
.env.*.local

# 测试覆盖率
coverage/

# 日志
*.log
npm-debug.log*

# IDE
.vscode/
.idea/

# OS
.DS_Store
Thumbs.db